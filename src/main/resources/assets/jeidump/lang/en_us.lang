# Command
jeidump.command.usage=/dumpjei [folder] [recipesPerTick] - dumps all JEI recipes and assets to <gameDir>/jeidump/<folder>.
jeidump.command.start=Starting JEI dump to %s ...
jeidump.command.in_progress=[JEI Dump] A dump is already in progress (%d recipes done so far).
jeidump.command.invalid_budget=[JEI Dump] Invalid recipesPerTick "%s", using default %d.
jeidump.command.budget=[JEI Dump] Budget: %d recipes/tick. Game may not be very responsive.
jeidump.command.scan_total=[JEI Dump] %d recipes across %d categories.
jeidump.command.progress=Dumped %d / %d recipes (%s).
jeidump.command.dedup.start=[JEI Dump] Starting background splitting...
jeidump.command.dedup.done=[JEI Dump] Reduced dump size from %s to %s with background splitting (%s%% of original size).
jeidump.command.dedup.none=[JEI Dump] Background splitting completed with no size reduction.
jeidump.command.dedup.disabled=[JEI Dump] Background splitting skipped (disabled in config).
jeidump.command.done=JEI dump complete: %d categories, %d recipes, %d unique ingredient icons. Output: %s
jeidump.command.error=JEI dump failed: %s
jeidump.command.no_runtime=JEI runtime is not ready yet. Open the JEI overlay once and try again.

