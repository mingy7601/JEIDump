# Configuration
jeidump.config.title=JEI Dump Configuration
jeidump.config.category.general=General
jeidump.config.defaultRecipesPerTick=Default Recipes Per Tick
jeidump.config.defaultRecipesPerTick.tooltip="Default number of recipes processed per client tick during a dump. Higher values are faster but may make the game (even) less responsive. Can be overridden per-run with /dumpjei <folder> <recipesPerTick>."
jeidump.config.recipeScale=Recipe Scale
jeidump.config.recipeScale.tooltip="Pixel multiplier applied to recipe layout PNG renders. Higher values produce crisper images but use more disk space. Requires a new dump to take effect."
jeidump.config.splitRecipeBackgrounds=Split Recipe Backgrounds
jeidump.config.splitRecipeBackgrounds.tooltip="Extract shared recipe backgrounds into a separate image per category when that reduces the total dump size. Disable this to keep every recipe as a standalone PNG."
jeidump.config.backgroundSplitImagesPerTick=Background Split Images Per Tick
jeidump.config.backgroundSplitImagesPerTick.tooltip="Maximum number of background-splitting image operations processed per client tick after recipe rendering finishes. Lower values reduce hitching but make the split phase take longer."
